# Configuration du fournisseur d'IA
# Choisissez entre "groq", "openai", ou "local"
AI_PROVIDER="groq"

# Modèle à utiliser (si applicable)
# Pour Groq, par exemple: "llama3-8b-8192", "llama3-70b-8192", "mixtral-8x7b-32768"
# Pour OpenAI, par exemple: "gpt-4o", "gpt-3.5-turbo"
AI_MODEL="llama3-8b-8192"

# --- Clés API ---
# Remplacez YOUR_API_KEY par votre véritable clé API
GROQ_API_KEY="YOUR_API_KEY"
OPENAI_API_KEY="YOUR_API_KEY"

# --- Configuration de la base de données ---
# Mettre à "True" pour voir les requêtes SQL dans la console
SQL_ECHO=False
