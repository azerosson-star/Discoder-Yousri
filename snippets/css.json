{
  "Reset CSS et Variables": {
    "prefix": "css-reset",
    "body": [
      ":root {",
      "    --primary-color: #${1:4A90E2};",
      "    --text-color: #${2:333333};",
      "    --bg-color: #${3:FFFFFF};",
      "    --border-color: #${4:DDDDDD};",
      "}",
      "",
      "* {",
      "    margin: 0;",
      "    padding: 0;",
      "    box-sizing: border-box;",
      "    font-family: ${5:'Segoe UI', sans-serif};",
      "}",
      "",
      "body {",
      "    background-color: var(--bg-color);",
      "    color: var(--text-color);",
      "    line-height: 1.6;",
      "}"
    ],
    "description": "Génère un reset CSS moderne avec des variables"
  },
  "Flexbox Centré": {
    "prefix": "css-flex-center",
    "body": [
      "display: flex;",
      "justify-content: center;",
      "align-items: center;"
    ],
    "description": "Raccourci pour centrer avec Flexbox"
  },
  "Grille CSS Auto-Responsive": {
    "prefix": "css-grid-auto",
    "body": [
      "display: grid;",
      "grid-template-columns: repeat(auto-fit, minmax(${1:250px}, 1fr));",
      "gap: ${2:20px};"
    ],
    "description": "Crée une grille responsive sans media queries"
  },
  "Effet Glassmorphism (Verre dépoli)": {
    "prefix": "css-glass",
    "body": [
      "background: rgba(${1:255, 255, 255}, ${2:0.2});",
      "backdrop-filter: blur(${3:10px});",
      "-webkit-backdrop-filter: blur(${3:10px});",
      "border: 1px solid rgba(${1:255, 255, 255}, 0.3);",
      "border-radius: ${4:15px};",
      "box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);"
    ],
    "description": "Applique un effet moderne de verre translucide"
  },
  "Scrollbar Personnalisée": {
    "prefix": "css-scrollbar",
    "body": [
      "::-webkit-scrollbar {",
      "    width: ${1:10px};",
      "}",
      "::-webkit-scrollbar-track {",
      "    background: ${2:#f1f1f1};",
      "}",
      "::-webkit-scrollbar-thumb {",
      "    background: ${3:#888};",
      "    border-radius: ${4:5px};",
      "}",
      "::-webkit-scrollbar-thumb:hover {",
      "    background: ${5:#555};",
      "}"
    ],
    "description": "Personnalise la barre de défilement du navigateur"
  },
  "Navbar Sticky (Fixée en haut avec flou)": {
    "prefix": "css-sticky-nav",
    "body": [
      "position: sticky;",
      "top: 0;",
      "z-index: ${1:1000};",
      "background-color: ${2:rgba(255, 255, 255, 0.9)};",
      "backdrop-filter: blur(${3:8px});",
      "-webkit-backdrop-filter: blur(${3:8px});",
      "border-bottom: 1px solid ${4:var(--border-color)};"
    ],
    "description": "Rend une barre de navigation collante avec un effet de flou (Glassmorphism)"
  },
  "Section Hero avec Overlay Sombre": {
    "prefix": "css-hero-overlay",
    "body": [
      "position: relative;",
      "background-image: url('${1:chemin/vers/image.jpg}');",
      "background-size: cover;",
      "background-position: center;",
      "min-height: ${2:100vh};",
      "display: flex;",
      "flex-direction: column;",
      "align-items: center;",
      "justify-content: center;",
      "color: ${3:#ffffff};",
      "z-index: 1;",
      "",
      "&::before {",
      "    content: '';",
      "    position: absolute;",
      "    top: 0; left: 0; right: 0; bottom: 0;",
      "    background: rgba(0, 0, 0, ${4:0.5});",
      "    z-index: -1;",
      "}"
    ],
    "description": "Section plein écran avec image de fond et voile sombre pour lisibilité"
  },
  "Variables Mode Sombre (Dark Mode)": {
    "prefix": "css-dark-mode",
    "body": [
      "/* Mode sombre basé sur les préférences du système */",
      "@media (prefers-color-scheme: dark) {",
      "    :root {",
      "        --bg-color: #${1:121212};",
      "        --text-color: #${2:ffffff};",
      "        --border-color: #${3:333333};",
      "        --primary-color: #${4:bb86fc};",
      "    }",
      "}",
      "",
      "/* Force le mode sombre via une classe sur le body (ex: toggle manuel) */",
      "body.dark-mode {",
      "    --bg-color: #${1:121212};",
      "    --text-color: #${2:ffffff};",
      "    --border-color: #${3:333333};",
      "}"
    ],
    "description": "Variables CSS pour le mode sombre automatique ou manuel"
  },
  "Tronquer le texte (Ellipsis)": {
    "prefix": "css-truncate",
    "body": [
      "white-space: nowrap;",
      "overflow: hidden;",
      "text-overflow: ellipsis;",
      "max-width: ${1:100%};"
    ],
    "description": "Coupe un texte trop long et ajoute des points de suspension (...)"
  }
}