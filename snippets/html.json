{
  "Structure HTML de base": {
    "prefix": "!html",
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"fr\">",
      "<head>",
      "    <meta charset=\"UTF-8\">",
      "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
      "    <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">",
      "    <title>${1:Titre de la page}</title>",
      "</head>",
      "<body>",
      "",
      "    <header>",
      "        <h1>${2:Bienvenue sur ma page}</h1>",
      "    </header>",
      "",
      "    <main>",
      "        <p>${3:Ceci est un paragraphe de test.}</p>",
      "    </main>",
      "",
      "    <footer>",
      "        <p>&copy; 2026 Mon Site Web</p>",
      "    </footer>",
      "",
      "</body>",
      "</html>"
    ],
    "description": "Génère une structure HTML de base",
  },



  "Page d'accueil complète": {
    "prefix": "html-accueil",
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"fr\">",
      "<head>",
      "    <meta charset=\"UTF-8\">",
      "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
      "    <title>${1:Mon Application} | Accueil</title>",
      "    <link rel=\"stylesheet\" href=\"${2:style.css}\">",
      "</head>",
      "<body>",
      "    <header class=\"navbar\">",
      "        <div class=\"logo\">${3:MonApp}</div>",
      "        <nav>",
      "            <ul class=\"nav-links\">",
      "                <li><a href=\"index.html\">Accueil</a></li>",
      "                <li><a href=\"#about\">À propos</a></li>",
      "                <li><a href=\"login.html\" class=\"btn-primary\">Connexion</a></li>",
      "            </ul>",
      "        </nav>",
      "    </header>",
      "",
      "    <main class=\"hero-section\">",
      "        <div class=\"hero-content\">",
      "            <h1>Bienvenue sur ${3:MonApp}</h1>",
      "            <p>${4:Votre slogan ici.}</p>",
      "            <a href=\"login.html\" class=\"btn-primary btn-large\">Commencer</a>",
      "        </div>",
      "    </main>",
      "",
      "    <script src=\"${5:script.js}\"></script>",
      "</body>",
      "</html>"
    ],
    "description": "Génère une page d'accueil avec navbar et hero section"
  },
  "Page de connexion": {
    "prefix": "html-login",
    "body": [
      "<!DOCTYPE html>",
      "<html lang=\"fr\">",
      "<head>",
      "    <meta charset=\"UTF-8\">",
      "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
      "    <title>Connexion | ${1:MonApp}</title>",
      "    <link rel=\"stylesheet\" href=\"${2:style.css}\">",
      "</head>",
      "<body class=\"bg-light\">",
      "    <div class=\"login-container\">",
      "        <div class=\"login-card\">",
      "            <h2>${3:Bon retour !}</h2>",
      "            <p>Veuillez vous connecter à votre compte.</p>",
      "            <form id=\"loginForm\">",
      "                <div class=\"input-group\">",
      "                    <label for=\"email\">Adresse e-mail</label>",
      "                    <input type=\"email\" id=\"email\" name=\"email\" required>",
      "                </div>",
      "                <div class=\"input-group\">",
      "                    <label for=\"password\">Mot de passe</label>",
      "                    <input type=\"password\" id=\"password\" name=\"password\" required>",
      "                </div>",
      "                <button type=\"submit\" class=\"btn-primary btn-full\">Se connecter</button>",
      "            </form>",
      "        </div>",
      "    </div>",
      "    <script src=\"${4:script.js}\"></script>",
      "</body>",
      "</html>"
    ],
    "description": "Génère une page de connexion complète",
  },
  "Grille de cartes (Responsive)": {
    "prefix": "html-cards",
    "body": [
      "<section class=\"grid-container\">",
      "    <div class=\"card\">",
      "        <img src=\"${1:image1.jpg}\" alt=\"${2:Description}\">",
      "        <h3>${3:Titre de la carte 1}</h3>",
      "        <p>${4:Description courte ici.}</p>",
      "        <a href=\"#\" class=\"btn-secondary\">${5:En savoir plus}</a>",
      "    </div>",
      "    <div class=\"card\">",
      "        <img src=\"${6:image2.jpg}\" alt=\"${7:Description}\">",
      "        <h3>${8:Titre de la carte 2}</h3>",
      "        <p>${9:Description courte ici.}</p>",
      "        <a href=\"#\" class=\"btn-secondary\">${5:En savoir plus}</a>",
      "    </div>",
      "</section>"
    ],
    "description": "Génère une structure de grille avec des cartes de contenu"
  },
  "Fenêtre Modale (Dialog)": {
    "prefix": "html-modal",
    "body": [
      "<dialog id=\"${1:myModal}\" class=\"modal\">",
      "    <div class=\"modal-content\">",
      "        <span class=\"close-btn\" onclick=\"document.getElementById('${1:myModal}').close()\">&times;</span>",
      "        <h2>${2:Titre de la modale}</h2>",
      "        <p>${3:Contenu de votre fenêtre modale ici...}</p>",
      "        <button class=\"btn-primary\">${4:Confirmer}</button>",
      "    </div>",
      "</dialog>",
      ""
    ],
    "description": "Génère une fenêtre modale native utilisant la balise <dialog>"
  },

  "Navbar avec Menu Burger": {
    "prefix": "html-navbar-burger",
    "body": [
      "<header class=\"navbar-sticky\">",
      "    <div class=\"logo\">${1:MonLogo}</div>",
      "    ",
      "    ",
      "    <button class=\"burger-menu\" aria-label=\"Ouvrir le menu\">",
      "        <span></span>",
      "        <span></span>",
      "        <span></span>",
      "    </button>",
      "",
      "    ",
      "    <nav class=\"nav-links\">",
      "        <ul>",
      "            <li><a href=\"#accueil\">Accueil</a></li>",
      "            <li><a href=\"#services\">Services</a></li>",
      "            <li><a href=\"#contact\">Contact</a></li>",
      "        </ul>",
      "    </nav>",
      "</header>"
    ],
    "description": "Structure HTML pour une navbar sticky intégrant un bouton burger"
  },
  "Section Hero prête pour l'Overlay": {
    "prefix": "html-hero-overlay",
    "body": [
      "<section class=\"hero-overlay\" style=\"background-image: url('${1:assets/hero-bg.jpg}');\">",
      "    <div class=\"hero-content\">",
      "        <h1>${2:Titre Principal}</h1>",
      "        <p>${3:Un sous-titre clair et percutant pour accrocher l'utilisateur.}</p>",
      "        <a href=\"#${4:contact}\" class=\"btn-primary\">${5:Passer à l'action}</a>",
      "    </div>",
      "</section>"
    ],
    "description": "Structure HTML de la section Hero compatible avec le CSS Overlay"
  },
  "Section avec Éléments à Animer (Scroll)": {
    "prefix": "html-scroll-section",
    "body": [
      "<section id=\"${1:services}\" class=\"section-padding\">",
      "    ",
      "    <h2 class=\"fade-in-up\">${2:Nos Services}</h2>",
      "    ",
      "    <div class=\"grid-container\">",
      "        <div class=\"card fade-in-up\">",
      "            <h3>${3:Service 1}</h3>",
      "            <p>${4:Description...}</p>",
      "        </div>",
      "        ",
      "        <div class=\"card fade-in-up\" style=\"transition-delay: 0.2s;\">",
      "            <h3>${5:Service 2}</h3>",
      "            <p>${6:Description...}</p>",
      "        </div>",
      "        <div class=\"card fade-in-up\" style=\"transition-delay: 0.4s;\">",
      "            <h3>${7:Service 3}</h3>",
      "            <p>${8:Description...}</p>",
      "        </div>",
      "    </div>",
      "</section>"
    ],
    "description": "Structure de section intégrant les classes d'animation au scroll"
  },
  "Système d'Onglets (Tabs)": {
    "prefix": "html-tabs",
    "body": [
      "<div class=\"tabs-container\">",
      "    ",
      "    <div class=\"tabs-header\">",
      "        <button class=\"tab-btn active\" data-tab=\"tab-1\">${1:Onglet 1}</button>",
      "        <button class=\"tab-btn\" data-tab=\"tab-2\">${2:Onglet 2}</button>",
      "        <button class=\"tab-btn\" data-tab=\"tab-3\">${3:Onglet 3}</button>",
      "    </div>",
      "",
      "    ",
      "    <div class=\"tabs-body\">",
      "        <div id=\"tab-1\" class=\"tab-content active\">",
      "            <h3>${1:Onglet 1}</h3>",
      "            <p>${4:Contenu du premier onglet...}</p>",
      "        </div>",
      "        <div id=\"tab-2\" class=\"tab-content\">",
      "            <h3>${2:Onglet 2}</h3>",
      "            <p>${5:Contenu du deuxième onglet...}</p>",
      "        </div>",
      "        <div id=\"tab-3\" class=\"tab-content\">",
      "            <h3>${3:Onglet 3}</h3>",
      "            <p>${6:Contenu du troisième onglet...}</p>",
      "        </div>",
      "    </div>",
      "</div>"
    ],
    "description": "Structure HTML complète pour le composant d'onglets (JS)"
  }
}
